# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: DataForSEO (hybrid scoring) ---
# When set, score_queries uses real search volume + KD + CPC + SERP features.
# When blank, scoring is LLM-estimated and the agent still runs end-to-end.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Optional: Slack notification on completed runs ---
SLACK_WEBHOOK_URL=

# --- Runtime ---
MAX_COST_USD=3.0
OUTPUT_DIR=./briefs
DATA_DIR=./data
